MAIL_TYPE=duckmail
NV_PASSWORD=YourSecurePassword123

# ---- DuckMail ----
# Domain accepts either duckmail.sbs or @duckmail.sbs; the app normalizes it.
DUCKMAIL_API_KEY=dk_xxxxxxxxxxxx
DUCKMAIL_DOMAIN=duckmail.sbs
# Override only if your network/proxy cannot reach the default API endpoint.
DUCKMAIL_API_BASE=https://api.duckmail.sbs

# ---- Legacy custom mail API ----
EMAIL_API=https://your-mail-api.example.com
EMAIL_AUTH=your_admin_key
EMAIL_DOMAIN=your-domain.com
# Stagger concurrent create requests; set 0 to disable.
EMAIL_CREATE_INTERVAL_SECONDS=1
EMAIL_CREATE_RETRIES=4
EMAIL_CREATE_RETRY_DELAY_SECONDS=1

# ---- AI Captcha ----
CAPTCHA_AI_ENABLED=true
# API key and base URL are auto-discovered from QWEN-PHOTO-API/API.txt
# Override here if needed:
# AI_VISION_API_KEY=sk-xxx
# AI_VISION_API_BASE=https://api.example.com/v1
AI_VISION_MODEL=qwen3.6-flash

# ---- Output (optional) ----
# Directory is recommended; the app creates timestamped key files inside it.
# Advanced usage: set a .txt file path to overwrite that exact file.
# NV_KEY_FILE=keys

# ---- Browser (optional) ----
# Leave empty to auto-detect Playwright browsers, Chrome, Edge, or Brave.
# CHROMIUM_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# PLAYWRIGHT_BROWSERS_PATH=C:\Users\YourName\AppData\Local\ms-playwright

# ---- Network proxy (optional) ----
# Fill these in the UI config page or here if your network needs a local proxy.
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897
# NO_PROXY=localhost,127.0.0.1
